{
  "expo": {
    "owner": "sbeverage",
    "name": "thrive-app",
    "slug": "thrive-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/piggy-with-flowers.png",
    "scheme": "thriveapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/piggy-with-flowers.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thriveinitiative.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "whatsapp",
          "fbapi",
          "fb-messenger-api",
          "fbauth2",
          "fbshareextension"
        ],
        "NSLocationWhenInUseUsageDescription": "This app uses location to show nearby discounts and causes on the map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app uses location to show nearby discounts and causes on the map.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "thriveapp",
            "CFBundleURLSchemes": [
              "thriveapp"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1079764121058-6q0ua6k2j17mmf6e38o4b9tc4f1n53rc"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "fb1693324062023615"
            ]
          }
        ]
      },
      "associatedDomains": [
        "applinks:thrive-web-jet.vercel.app"
      ]
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.thriveinitiative.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/piggy-with-flowers.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "thrive-web-jet.vercel.app",
              "pathPrefix": "/verify"
            },
            {
              "scheme": "https",
              "host": "thrive-web-jet.vercel.app",
              "pathPrefix": "/verify-email"
            },
            {
              "scheme": "https",
              "host": "thrive-web-jet.vercel.app",
              "pathPrefix": "/signup"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "thriveapp"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to show nearby discounts and causes on the map."
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      [
        "react-native-fbsdk-next",
        {
          "appID": "1693324062023615",
          "clientToken": "91df4ea8e91af96eba396afe8cc5f233",
          "displayName": "Thrive",
          "scheme": "fb1693324062023615",
          "iosUserTrackingPermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8650ede9-cbf0-47a2-8b14-a47000acce94"
      }
    }
  }
}
